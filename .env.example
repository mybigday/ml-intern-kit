# Copy to .env and fill in. .env is gitignored.

# Hugging Face — required for gated/private repos and HF Jobs submission
HF_TOKEN=

# Anthropic / OpenAI — only if you'll use Claude Code / Codex against the API
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional monitoring (Trackio is the default and needs nothing)
WANDB_API_KEY=
WANDB_PROJECT=ml-intern-kit

# Default Hub namespace for push_to_hub. The training scripts use this when
# --hub-model-id is not set explicitly.
HF_HUB_NAMESPACE=

# Speed up Hub up/downloads via hf-transfer (Rust)
HF_HUB_ENABLE_HF_TRANSFER=1

# Quieter tokenizer warnings inside DataLoader workers
TOKENIZERS_PARALLELISM=false
